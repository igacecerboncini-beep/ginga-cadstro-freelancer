<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Cadastro Freelancer - Ginga</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <style>
    body { font-family: Arial; background:#f5f5f5; padding:20px; }
    .container { max-width:800px; margin:auto; background:#fff; padding:20px; border-radius:10px; }
    h2 { color:#ff6a00; text-align:center; }
    label { display:block; margin-top:10px; }
    input, textarea, select { width:100%; padding:8px; margin-top:5px; border-radius:5px; border:1px solid #ccc; }
    .row { display:flex; gap:10px; }
    .row div { flex:1; }
    button { margin-top:20px; padding:12px; width:100%; background:#556b2f; color:#fff; border:none; border-radius:8px; font-size:16px; }
    .logo { text-align:center; margin-bottom:20px; }
    .logo img { max-width:150px; }
  </style>
</head>
<body>

<div class="container">
  <div class="logo">
    <img src="https://via.placeholder.com/150x150.png?text=GINGA" alt="Logo">
  </div>

  <h2>Ficha Cadastral – Freelancer</h2>

  <form id="form">

    <h3>Dados Pessoais</h3>
    <label>Nome Completo</label>
    <input type="text" id="nome">

    <label>CPF</label>
    <input type="text" id="cpf">

    <label>Email</label>
    <input type="email" id="email">

    <h3>Dados Profissionais</h3>
    <label>Área de Atuação</label>
    <input type="text" id="area">

    <label>Serviços</label>
    <textarea id="servicos"></textarea>

    <h3>Dados Bancários</h3>
    <label>Banco</label>
    <input type="text" id="banco">

    <label>Chave PIX</label>
    <input type="text" id="pix">

    <button type="button" onclick="gerarPDF()">Finalizar e Gerar PDF</button>

  </form>
</div>

<script>
async function gerarPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF();

  doc.setTextColor(255,106,0);
  doc.setFontSize(18);
  doc.text("Ficha Cadastral - Ginga Rooftop", 20, 20);

  doc.setTextColor(0,0,0);
  doc.setFontSize(12);

  doc.text("Nome: " + document.getElementById("nome").value, 20, 40);
  doc.text("CPF: " + document.getElementById("cpf").value, 20, 50);
  doc.text("Email: " + document.getElementById("email").value, 20, 60);

  doc.text("Área: " + document.getElementById("area").value, 20, 80);
  doc.text("Serviços: " + document.getElementById("servicos").value, 20, 90);

  doc.text("Banco: " + document.getElementById("banco").value, 20, 110);
  doc.text("PIX: " + document.getElementById("pix").value, 20, 120);

  doc.save("cadastro_freelancer.pdf");
}
</script>

</body>
</html>
